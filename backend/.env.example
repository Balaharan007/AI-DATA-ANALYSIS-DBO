# Groq API key - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Groq models (override if Groq deprecates/renames these)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_TEXT_MODEL=kimi-k2-instruct
GROQ_VISION_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# CORS - must include the frontend origin
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Where uploaded datasets / generated reports are persisted on disk
DATA_DIR=./data

# MongoDB settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=information_users
MONGODB_USERS_COLLECTION=users

# JWT settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google Drive Integration
# Enable Google Drive upload for reports
GOOGLE_DRIVE_ENABLED=false

# Option 1: Path to service account JSON key file
# Get this from Google Cloud Console > IAM > Service Accounts > Create Key > JSON
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Option 2: Service account JSON content directly (base64 encoded or raw)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option 3: Use the path in the config (app/config.py reads from env)
# GOOGLE_DRIVE_CREDENTIALS_PATH=./service-account.json

# Google Drive folder ID where reports will be uploaded
# 1. Create a folder in Google Drive
# 2. Share it with the service account email (from the JSON key)
# 3. Copy the folder ID from the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=