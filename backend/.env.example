# Groq API key - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Groq models (override if Groq deprecates/renames these)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_TEXT_MODEL=kimi-k2-instruct
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# CORS - must include the frontend origin
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Where uploaded datasets / generated reports are persisted on disk
DATA_DIR=./data

# MongoDB settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=information_users
MONGODB_USERS_COLLECTION=users

# JWT settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Telegram Bot settings
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8974667061:AAH49-3urvoK8OkodO9le-vHBZkMueI69vQ

# The chat/user/group/channel ID to send files to.
# Easiest way to get it: message your bot, then visit
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# and look for "chat":{"id": ...}
TELEGRAM_CHAT_ID=6798365742