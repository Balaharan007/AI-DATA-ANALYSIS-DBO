# =============================================================================
# Docker ignore - files/folders NOT copied to build context
# =============================================================================

# Git
.git
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Backend
backend/.venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.mypy_cache/
backend/.coverage
backend/htmlcov/
backend/*.egg-info/
backend/dist/
backend/build/
backend/data/
backend/*.log
backend/.env
backend/.env.local
backend/.env.*.local

# Frontend
frontend/node_modules/
frontend/.output/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.wrangler/
frontend/*.log
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.DS_Store

# Repo-root extras not needed in the image
img_video_link/
Sample_dataset/
zip/
*.md
*.zip
bash.exe.stackdump

# Misc
*.tar.gz
*.bak
*.tmp
*.temp
