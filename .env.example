# Copy this file to ".env" in the repo root and fill in real values.
# docker-compose reads this file automatically (env_file: .env on the backend service).

# Required - https://console.groq.com/keys
GROQ_API_KEY=your groq api key here

# Required - use a long random string in production (32+ chars)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=information_users
MONGODB_USERS_COLLECTION=users

# JWT settings
JWT_SECRET_KEY=k8Hs93jd_x7Lp2Qw!mN4vRt6Yb1Zc0Ae9Fg
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Backend URL the frontend will call — used at BUILD time, baked into the JS bundle
VITE_API_BASE_URL=http://localhost:3000

# Optional - Telegram bot integration
TELEGRAM_BOT_TOKEN=8974667061:AAH49-3urvoK8OkodO9le-vHBZkMueI69vQ
TELEGRAM_CHAT_ID=6798365742
# Optional - override default Groq models
